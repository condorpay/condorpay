{
	"name": "@condorpay/medusa",
	"version": "0.2.0",
	"description": "CondorPay Medusa v2 payment providers — Bre-B QR and Wompi (Colombia)",
	"license": "MIT",
	"type": "module",
	"main": "./dist/cjs/index.js",
	"module": "./dist/esm/index.js",
	"types": "./dist/esm/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/esm/index.d.ts",
				"default": "./dist/esm/index.js"
			},
			"require": {
				"types": "./dist/cjs/index.d.ts",
				"default": "./dist/cjs/index.js"
			}
		},
		"./breb": {
			"import": {
				"types": "./dist/esm/breb-entry.d.ts",
				"default": "./dist/esm/breb-entry.js"
			},
			"require": {
				"types": "./dist/cjs/breb-entry.d.ts",
				"default": "./dist/cjs/breb-entry.js"
			}
		},
		"./wompi": {
			"import": {
				"types": "./dist/esm/wompi-entry.d.ts",
				"default": "./dist/esm/wompi-entry.js"
			},
			"require": {
				"types": "./dist/cjs/wompi-entry.d.ts",
				"default": "./dist/cjs/wompi-entry.js"
			}
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"engines": {
		"node": ">=20"
	},
	"peerDependencies": {
		"@condorpay/co": "*",
		"@condorpay/core": "*",
		"@medusajs/framework": ">=2.5.0"
	},
	"devDependencies": {
		"@condorpay/co": "workspace:*",
		"@condorpay/core": "workspace:*",
		"@medusajs/framework": "^2.5.0",
		"@medusajs/types": "^2.13.5",
		"@medusajs/utils": "^2.13.5",
		"@types/node": "^25.5.0"
	},
	"scripts": {
		"build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'},null,2))\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check src"
	}
}
